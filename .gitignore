# ============================================================
# .gitignore — Vibe Boilerplate
# ============================================================
# Since this project has no build step, there are very few
# files to ignore. Expand this as your project grows.
# ============================================================

# --- OS files ---
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# --- Editor / IDE directories ---
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# --- Local notes ---
*.local
*.local.*
notes.txt
TODO.local.md

# --- Environment / secrets ---
# (should never exist in a static project, but just in case)
.env
.env.*
!.env.example

# --- Logs ---
*.log
npm-debug.log*
yarn-debug.log*

# --- If you ever temporarily add a local server or test runner ---
node_modules/
.cache/
dist/
build/

# --- Temporary files ---
*.tmp
*.bak
*.orig
